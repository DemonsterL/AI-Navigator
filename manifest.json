{
  "manifest_version": 3,
  "name": "AI Navigator",
  "author": "Ning Li",
  "version": "1.0.0",
  "description": "Smart navigation sidebar for Gemini, ChatGPT, Grok, and Khoj conversations.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://app.khoj.dev/*",
        "https://chatgpt.com/*",
        "https://x.com/*",
        "https://grok.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ]
}